{
    "name": "vuryss/doctrine-lazy-json-odm",
    "description": "A high-performance Doctrine JSON ODM with lazy loading using vuryss/serializer v4",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Georgi Georgiev",
            "email": "vuryss@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "doctrine/dbal": "^4.4.2",
        "doctrine/orm": "^3.6.2",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/config": "^7.4 || ^8.0",
        "vuryss/serializer": "^4.0",
        "halaxa/json-machine": "^1.2.6"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1.40",
        "captainhook/captainhook": "^5.28.5",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "captainhook/hook-installer": "^1.0.4",
        "ramsey/conventional-commits": "^1.7",
        "symfony/phpunit-bridge": "^7.4 || ^8.0",
        "mockery/mockery": "^1.6.12"
    },
    "config": {
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Vuryss\\DoctrineLazyJsonOdm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vuryss\\DoctrineLazyJsonOdm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.4 || ^8.0"
        }
    },
    "scripts": {
        "lint:php": "find src tests config -name '*.php' -exec php -l {} \\; | (! grep -v \"No syntax errors detected\")",
        "test": "pest --no-coverage",
        "test:lowest": [
            "@composer update --no-interaction --no-progress --prefer-dist --prefer-lowest --prefer-stable",
            "@test"
        ],
        "test:highest": [
            "@composer update --no-interaction --no-progress --prefer-dist",
            "@test"
        ],
        "coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage-html coverage"
    }
}
