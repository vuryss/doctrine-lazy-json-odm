{
    "name": "vuryss/doctrine-lazy-json-odm",
    "description": "A high-performance Doctrine JSON ODM with lazy loading using vuryss/serializer v2",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Georgi Georgiev",
            "email": "vuryss@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^4.4.1",
        "doctrine/orm": "^3.5.8",
        "symfony/framework-bundle": "^7.4.1",
        "symfony/dependency-injection": "^7.4.2",
        "symfony/config": "^7.4.1",
        "vuryss/serializer": "^3.0",
        "halaxa/json-machine": "^1.2.6"
    },
    "require-dev": {
        "pestphp/pest": "^4.2",
        "phpstan/phpstan": "^2.1.33",
        "captainhook/captainhook": "^5.27.4",
        "friendsofphp/php-cs-fixer": "^3.92.1",
        "captainhook/hook-installer": "^1.0.4",
        "ramsey/conventional-commits": "^1.6",
        "symfony/phpunit-bridge": "^7.4",
        "mockery/mockery": "^1.6.12"
    },
    "config": {
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Vuryss\\DoctrineLazyJsonOdm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vuryss\\DoctrineLazyJsonOdm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    },
    "scripts": {
        "test": "pest --no-coverage",
        "coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage-html coverage"
    }
}
